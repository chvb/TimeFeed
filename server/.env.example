NODE_ENV=production
PORT=3030
# Pflicht: ohne JWT_SECRET startet der Server nicht. Erzeugen mit: openssl rand -hex 48
JWT_SECRET=
JWT_EXPIRE_TIME=8h
DATABASE_URL=sqlite:./database.sqlite
# Öffentliche Basis-URL (auch in den SystemSettings als publicUrl pflegbar)
PUBLIC_URL=https://timefeed.de
CORS_ORIGIN=https://timefeed.de
# Reverse-Proxy: loopback | true | false | Hop-Anzahl | IP/CIDR-Liste
TRUST_PROXY=loopback
# FORCE_HTTPS=true aktiviert HSTS + upgrade-insecure-requests (nur hinter echtem TLS)
# SMTP und S3 werden in der Admin-UI gepflegt (EmailSettings/StorageSettings), nicht hier.
# Seed-Passwörter für Erstinstallation (optional, sonst Zufallswerte im Log):
# SEED_ADMIN_PASSWORD=
