<?xml version="1.0" encoding="utf-8"?>
<!--
  Keine Daten-Extraktion (Cloud-Backup / Device-Transfer):
  WebView-Storage kann Session-Tokens des Terminals enthalten.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
